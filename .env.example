# Copy to .env and fill in your values.
# .env is sourced automatically by the Makefile.

UNIFI_HOST=https://10.1.2.1
UNIFI_API_KEY=
DEFAULT_TARGET=10.1.2.241

# Optional overrides (defaults shown)
# UNIFI_SITE=default
# UNIFI_INSECURE_SKIP_VERIFY=true
# TXT_OWNER=docker-external-dns
# TXT_PREFIX=
# POLICY=sync
# RECONCILE_INTERVAL=5m
# LOG_LEVEL=info
# LOG_FORMAT=text
# DRY_RUN=false

# Optional container labels:
# external-dns.target=<ip-or-hostname>
# external-dns.routers.<router>.target=<ip-or-hostname>
# external-dns.routers.<router>.skip=true
